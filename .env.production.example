APP_NAME=Dance CRM API
APP_VERSION=0.1.0
DEBUG=false

POSTGRES_USER=dance_crm
POSTGRES_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD
POSTGRES_DB=dance_crm
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

JWT_SECRET_KEY=CHANGE_ME_TO_AT_LEAST_64_RANDOM_CHARACTERS
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

LOG_LEVEL=INFO
LOG_SQL=false
LOG_FILE=logs/app.log
AUDIT_LOG_FILE=logs/audit.log
LOG_MAX_BYTES=10485760
